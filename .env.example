# Copy to .env.local (secrets) and .env (DATABASE_URL) and fill in.
# All keys are server-side only — never prefix with NEXT_PUBLIC_.

# --- Phase 1 (local) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Local SQLite file (used by Prisma CLI + libSQL adapter). Lives in .env.
DATABASE_URL="file:./dev.db"

# --- Phase 2 (deploy) ---
# Turso (libSQL). Swap DATABASE_URL to the libsql:// URL and add the token.
# DATABASE_URL="libsql://<db>.turso.io"
TURSO_AUTH_TOKEN=
# Single-password cookie auth (middleware).
AUTH_PASSWORD=
AUTH_COOKIE_SECRET=
