# Copy secrets to .env.local, and DATABASE_URL to .env, then fill in.
# All keys are server-side only — never prefix with NEXT_PUBLIC_.

# --- Phase 1 (local) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Local SQLite file (used by Prisma CLI + libSQL adapter). Lives in .env.
DATABASE_URL="file:./dev.db"

# --- Phase 2 (deploy & secure) ---

# Single-password cookie auth (proxy.ts + /api/login). Required for the app to
# be reachable once deployed. Set BOTH locally to test login, and in Vercel.
AUTH_PASSWORD=choose-a-strong-password
# HMAC key for signing the auth cookie. Generate a random 32+ byte value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_COOKIE_SECRET=

# Turso (libSQL) — PRODUCTION DB. Set these in the Vercel project env, NOT here.
# Next.js loads .env.local at higher precedence than .env, so putting a libsql://
# DATABASE_URL in .env.local makes `npm run dev` hit Turso instead of the local
# file:./dev.db (and you'll get "no such table" until Turso is migrated).
# Keep local dev on the file above; let Vercel supply these two in production:
#   DATABASE_URL="libsql://<db>-<org>.turso.io"
#   TURSO_AUTH_TOKEN=<token>
